# Copy to `fastlane/.env.secret` and fill in your actual values.
# This file is consumed automatically by fastlane when running lanes locally.

# --- App Store Connect API key -------------------------------------------------
# Create one at: App Store Connect > Users and Access > Integrations >
# App Store Connect API. Generate a key with role "App Manager".
#
# Fastlane needs two views of the same key:
#   - JSON config (for direct CLI tools: `fastlane match`, `fastlane deliver ...`)
#   - Raw .p8     (for the `app_store_connect_api_key` Fastfile helper)
#
# Generate the JSON once with:
#   mkdir -p ~/.appstoreconnect
#   jq -Rn --arg k "$(cat /absolute/path/to/AuthKey_XXXXXXXXXX.p8)" \
#     '{key_id:"XXXXXXXXXX", issuer_id:"00000000-0000-0000-0000-000000000000", key:$k, in_house:false}' \
#     > ~/.appstoreconnect/asc_api_key.json
#   chmod 600 ~/.appstoreconnect/asc_api_key.json

APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/to/asc_api_key.json
APP_STORE_CONNECT_API_KEY_P8_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
APP_STORE_CONNECT_API_KEY_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_API_KEY_ISSUER_ID=00000000-0000-0000-0000-000000000000

# --- fastlane match (code signing) --------------------------------------------
# URL of the private GitHub repo that stores your encrypted certs/profiles.
MATCH_GIT_URL=git@github.com:lukaskaibel/logit-certs.git
# Passphrase used to encrypt the certs repo. Must match across machines + CI.
MATCH_PASSWORD=change-me

# --- Optional -----------------------------------------------------------------
# Only needed if your Apple account sits on multiple teams.
# FASTLANE_ITC_TEAM_ID=123456789
# FASTLANE_APPLE_ID=lukas.kaibel@gmail.com
