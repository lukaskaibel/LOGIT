# Apple currently requires exactly ONE iPhone display size - the 6.9" tier.
# Screenshots for smaller devices (6.5", 5.5") are auto-derived from the
# 6.9" capture, so uploading a second size would just show the same images
# twice in App Store Connect. Keep this list at one device unless Apple
# introduces a new required size tier.
devices([
  "iPhone 17 Pro Max" # 6.9" - required display size
])

languages([
  "en-US",
  "de-DE",
  "es-MX",
  "es-ES",
  "fr-FR",
  "pt-BR",
  "ja",
  "ko",
  "it"
])

# Xcode scheme + workspace/project pair used by snapshot's `xcodebuild` call.
# Using a dedicated screenshots-only scheme so the unrelated LOGITTests bundle
# never needs to compile for snapshot runs.
scheme("LOGITScreenshots")
project("./LOGIT.xcodeproj")

# UI test bundle that calls `snapshot(...)`.
test_target_name("LOGITUITests")

# Output layout.
output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)

# Clean 9:41 status bar with full battery + Wi-Fi + cellular signal.
override_status_bar(true)

# Parallelize across simulators (much faster on multi-core Macs).
concurrent_simulators(true)

# Skip the HTML summary file - the metadata flow doesn't need it.
skip_open_summary(true)

# Stop the first failing test from aborting the whole run so we still get
# partial screenshots to iterate on.
stop_after_first_error(false)
