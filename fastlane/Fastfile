# Fastfile for LOGIT
#
# Every App Store Connect call authenticates with an API key (`.p8`) rather
# than an Apple ID password, so no 2FA prompts ever appear. Secrets are read
# from `fastlane/.env.secret` locally and from GitHub Actions secrets in CI.
#
# Common lanes:
#
#   bundle exec fastlane screenshots           # capture + frame locally
#   bundle exec fastlane refresh_screenshots   # capture + frame + upload
#   bundle exec fastlane metadata              # upload text metadata
#   bundle exec fastlane beta                  # TestFlight build
#   bundle exec fastlane release               # submit to App Store review

fastlane_version "2.227.0"
default_platform(:ios)

# Teach frameit about iPhone 15/16/17 sizes (upstream ships an outdated list
# that maxes out at iPhone 14 Pro Max, so new screenshots error out as
# "Unsupported screen size" without this patch).
require_relative "frameit_devices_patch"
require "fileutils"

# ------------------------------------------------------------------------------
# Paths / constants
# ------------------------------------------------------------------------------
XCODE_PROJECT   = "LOGIT.xcodeproj"
XCODE_SCHEME    = "LOGIT"
SCREENSHOT_SCHEME = "LOGITScreenshots"
UITEST_TARGET   = "LOGITUITests"
# Anchor to this file so paths stay valid after actions that `chdir` (e.g.
# `frame_screenshots` moves into `screenshots/` while running).
METADATA_DIR    = File.expand_path("metadata", __dir__)
SCREENSHOT_DIR  = File.expand_path("screenshots", __dir__)

# Dotenv: load `.env.secret` so local runs pick up API key paths without
# polluting the shell. CI passes the same values as env vars directly.
DOTENV = File.expand_path(".env.secret", __dir__)
if File.exist?(DOTENV)
  File.foreach(DOTENV) do |line|
    next if line.strip.empty? || line.strip.start_with?("#")
    key, value = line.strip.split("=", 2)
    ENV[key] ||= value if key && value
  end
end

# ------------------------------------------------------------------------------
# App Store Connect API key
# ------------------------------------------------------------------------------
def asc_api_key
  # CI path: base64-encoded `.p8` contents in APP_STORE_CONNECT_API_KEY_CONTENT.
  # Local path: absolute filesystem path in APP_STORE_CONNECT_API_KEY_PATH.
  if ENV["APP_STORE_CONNECT_API_KEY_CONTENT"] && !ENV["APP_STORE_CONNECT_API_KEY_CONTENT"].empty?
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false
    )
  else
    # Prefer the raw .p8 path when present (the Fastfile helper wants a .p8
    # file), otherwise fall back to whatever APP_STORE_CONNECT_API_KEY_PATH
    # points at.
    p8_path = ENV["APP_STORE_CONNECT_API_KEY_P8_PATH"] || ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
      key_filepath: p8_path,
      in_house: false
    )
  end
end

# Live Activity marketing shot is a full-bleed Lock Screen mockup (no device
# bezel). frameit skips it when `title.strings` has no `07_LiveActivity` entry;
# copy the raw snapshot to `*_framed.png` so `deliver` still finds the asset.
def copy_live_activity_showcase_as_framed(base_dir)
  Dir.glob(File.join(base_dir, "**", "iPhone *-07_LiveActivity.png")).each do |src|
    next if src.end_with?("_framed.png")

    dest = src.sub(/\.png\z/, "_framed.png")
    FileUtils.cp(src, dest)
    UI.success("Live Activity showcase (no device frame): copied to #{dest}")
  end
end

# ------------------------------------------------------------------------------
# Screenshot lanes
# ------------------------------------------------------------------------------
platform :ios do

  desc "Capture and frame localized App Store screenshots locally (no upload)."
  lane :screenshots do
    capture_ios_screenshots(
      project: XCODE_PROJECT,
      scheme: SCREENSHOT_SCHEME,
      output_directory: SCREENSHOT_DIR,
      clear_previous_screenshots: true,
      override_status_bar: true,
      concurrent_simulators: true
    )
    frame_screenshots(path: SCREENSHOT_DIR)
    copy_live_activity_showcase_as_framed(SCREENSHOT_DIR)
  end

  desc "Re-run frameit only (cheap: reuses existing raw PNGs)."
  lane :reframe do
    frame_screenshots(path: SCREENSHOT_DIR)
    copy_live_activity_showcase_as_framed(SCREENSHOT_DIR)
  end

  desc "Upload already-framed screenshots to App Store Connect."
  lane :upload_screenshots do
    api_key = asc_api_key

    upload_to_app_store(
      api_key: api_key,
      metadata_path: METADATA_DIR,
      screenshots_path: SCREENSHOT_DIR,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

  desc "Capture, frame and upload screenshots in one shot."
  lane :refresh_screenshots do
    screenshots
    upload_screenshots
  end

  # ----------------------------------------------------------------------------
  # Metadata lane (description / release notes / keywords)
  # ----------------------------------------------------------------------------
  desc "Upload App Store text metadata (description, keywords, release notes)."
  lane :metadata do
    api_key = asc_api_key

    upload_to_app_store(
      api_key: api_key,
      metadata_path: METADATA_DIR,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

  desc "Pull current live screenshots from App Store Connect into fastlane/screenshots/*."
  lane :download_screenshots do
    key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    UI.user_error!("APP_STORE_CONNECT_API_KEY_PATH must point at the JSON key config") if key_path.nil? || key_path.empty?

    Dir.chdir("..") do
      sh "bundle exec fastlane deliver download_screenshots --api_key_path '#{key_path}' --screenshots_path '#{SCREENSHOT_DIR}' --force"
    end
  end

  desc "Pull current live metadata from App Store Connect into fastlane/metadata/*."
  lane :download_metadata do
    # `deliver` is an upload-only action; the *download* mode is exposed via
    # the `fastlane deliver download_metadata` sub-command, so we shell out.
    key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"] ||
               ENV["APP_STORE_CONNECT_API_KEY_JSON_PATH"]
    UI.user_error!("APP_STORE_CONNECT_API_KEY_PATH must point at the JSON key config") if key_path.nil? || key_path.empty?

    Dir.chdir("..") do
      sh "bundle exec fastlane deliver download_metadata --api_key_path '#{key_path}' --metadata_path '#{METADATA_DIR}' --force"
    end
  end

  # ----------------------------------------------------------------------------
  # Build + ship lanes
  # ----------------------------------------------------------------------------
  desc "Build and upload a new TestFlight build."
  lane :beta do
    api_key = asc_api_key

    sync_code_signing(
      type: "appstore",
      readonly: is_ci,
      api_key: api_key
    )

    increment_build_number(
      xcodeproj: XCODE_PROJECT,
      build_number: latest_testflight_build_number(api_key: api_key).to_i + 1
    )

    build_app(
      project: XCODE_PROJECT,
      scheme: XCODE_SCHEME,
      output_directory: "./fastlane/builds",
      export_method: "app-store",
      clean: true,
      include_bitcode: false,
      include_symbols: true
    )

    # Release notes for TestFlight testers.
    changelog = begin
      File.read(File.join(METADATA_DIR, "en-US", "release_notes.txt")).strip
    rescue StandardError
      "Internal build."
    end

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      changelog: changelog,
      distribute_external: false
    )
  end

  desc "Populate the current App Store release (metadata + screenshots) without submitting for review."
  lane :prepare_release do |options|
    api_key = asc_api_key

    # Pull the marketing version off the Xcode project so the lane is driven
    # by the source of truth rather than requiring CLI overrides. Caller can
    # still force a version via `fastlane prepare_release app_version:4.2`.
    version_number = options[:app_version] || get_version_number(
      xcodeproj: XCODE_PROJECT,
      target: XCODE_SCHEME
    )

    upload_to_app_store(
      api_key: api_key,
      app_version: version_number,
      metadata_path: METADATA_DIR,
      screenshots_path: SCREENSHOT_DIR,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

  desc "Ship a new App Store release (build + metadata + screenshots + submit)."
  lane :release do |options|
    api_key = asc_api_key

    sync_code_signing(
      type: "appstore",
      readonly: is_ci,
      api_key: api_key
    )

    increment_build_number(
      xcodeproj: XCODE_PROJECT,
      build_number: latest_testflight_build_number(api_key: api_key).to_i + 1
    )

    build_app(
      project: XCODE_PROJECT,
      scheme: XCODE_SCHEME,
      output_directory: "./fastlane/builds",
      export_method: "app-store",
      clean: true,
      include_bitcode: false,
      include_symbols: true
    )

    upload_to_app_store(
      api_key: api_key,
      metadata_path: METADATA_DIR,
      screenshots_path: SCREENSHOT_DIR,
      submit_for_review: options.fetch(:submit_for_review, true),
      automatic_release: options.fetch(:automatic_release, false),
      force: true,
      skip_binary_upload: false,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false
      }
    )
  end

  # ----------------------------------------------------------------------------
  # Convenience
  # ----------------------------------------------------------------------------
  desc "Generate a fresh App Store Connect API key (prints instructions)."
  lane :setup_help do
    UI.message("See fastlane/.env.secret.example for required environment variables.")
    UI.message("App Store Connect > Users and Access > Integrations > App Store Connect API")
  end

end
